#!/bin/bash
# Versioned pre-push hook: run the full health check before publishing, so the
# slow build/test/lint happens once per push instead of on every commit.
# Activate once with: scripts/install-hooks.sh
# Bypass for an emergency push: git push --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
ZERO="0000000000000000000000000000000000000000"

# git feeds "<local ref> <local sha> <remote ref> <remote sha>" lines on stdin,
# one per ref being pushed. Collect the files that differ across everything being
# pushed; a docs-only push can then skip the check (docs/ is prose, excluded from
# the lint checks and unable to affect the build or tests). If a range can't be
# computed (e.g. a brand-new branch with no remote counterpart and no main to
# diff against), fall back to running the full check.
changed=""
force_check=0
while read -r _localref localsha _remoteref remotesha; do
  [ "$localsha" = "$ZERO" ] && continue  # branch deletion — nothing to build
  if [ "$remotesha" = "$ZERO" ]; then
    # New branch on the remote: diff against the fork point from the default
    # branch so only this branch's own changes are considered.
    base="$(git merge-base "$localsha" origin/main 2>/dev/null \
      || git merge-base "$localsha" main 2>/dev/null || true)"
  else
    base="$remotesha"
  fi
  if [ -z "$base" ]; then
    force_check=1
    break
  fi
  changed+="$(git diff --name-only "$base" "$localsha")"$'\n'
done

if [ "$force_check" -eq 0 ]; then
  nondocs="$(printf '%s\n' "$changed" | grep -vE '^docs/|^$' || true)"
  if [ -z "$nondocs" ]; then
    echo "pre-push: docs-only (or nothing) to push; skipping scripts/check.sh"
    exit 0
  fi
fi

exec "$REPO_ROOT/scripts/check.sh"
